---
import { nav } from '@/config/site';

const commandItems = [{ label: 'Ana sayfa', href: '/' }, ...nav];
---

<div class="command-palette" data-command-palette hidden>
  <div class="command-palette__backdrop" data-command-close></div>
  <section
    class="command-palette__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="command-palette-title"
  >
    <header class="command-palette__header">
      <h2 id="command-palette-title">Hızlı erişim</h2>
      <p><kbd>Ctrl/Cmd</kbd> + <kbd>K</kbd></p>
    </header>

    <label class="command-palette__search" for="command-palette-input">
      <span class="sr-only">Sayfa ara</span>
      <input
        id="command-palette-input"
        type="search"
        placeholder="Sayfa ara..."
        autocomplete="off"
        data-command-input
      />
    </label>

    <ul class="command-palette__list" role="list" data-command-list>
      {
        commandItems.map((item) => (
          <li data-command-item data-command-label={item.label.toLocaleLowerCase('tr-TR')}>
            <a href={item.href} data-command-link>
              <span>{item.label}</span>
              <span class="command-palette__arrow" aria-hidden="true">↵</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</div>

<script>
  const root = document.querySelector('[data-command-palette]');
  if (root) {
    const input = root.querySelector('[data-command-input]');
    const listItems = Array.from(root.querySelectorAll('[data-command-item]'));
    const closeTargets = root.querySelectorAll('[data-command-close]');

    let lastFocus = null;

    const openPalette = () => {
      lastFocus = document.activeElement;
      root.hidden = false;
      document.body.style.overflow = 'hidden';
      window.setTimeout(() => input?.focus(), 0);
    };

    const closePalette = () => {
      root.hidden = true;
      document.body.style.overflow = '';
      if (input) input.value = '';
      for (const item of listItems) item.hidden = false;
      if (lastFocus && typeof lastFocus.focus === 'function') {
        lastFocus.focus();
      }
    };

    const filterItems = () => {
      const query = (input?.value ?? '').toLocaleLowerCase('tr-TR').trim();
      for (const item of listItems) {
        const label = item.getAttribute('data-command-label') ?? '';
        item.hidden = query.length > 0 && !label.includes(query);
      }
    };

    document.addEventListener('keydown', (event) => {
      const key = event.key.toLowerCase();
      if ((event.ctrlKey || event.metaKey) && key === 'k') {
        event.preventDefault();
        if (root.hidden) {
          openPalette();
        } else {
          closePalette();
        }
      } else if (key === 'escape' && !root.hidden) {
        event.preventDefault();
        closePalette();
      }
    });

    closeTargets.forEach((el) => el.addEventListener('click', closePalette));
    root.querySelectorAll('[data-command-link]').forEach((link) => {
      link.addEventListener('click', () => {
        closePalette();
      });
    });
    input?.addEventListener('input', filterItems);
  }
</script>

<style>
  .command-palette {
    position: fixed;
    inset: 0;
    z-index: 160;
    display: grid;
    place-items: start center;
    padding: calc(var(--header-height) + var(--space-sm)) var(--container-padding) var(--space-md);
  }

  .command-palette__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(3, 4, 8, 0.65);
    backdrop-filter: blur(6px);
  }

  .command-palette__panel {
    position: relative;
    width: min(40rem, 100%);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-strong);
    background: linear-gradient(165deg, var(--color-bg-elevated) 0%, var(--color-surface) 100%);
    box-shadow: var(--shadow-panel), 0 0 0 1px rgba(90, 125, 168, 0.18);
    overflow: hidden;
  }

  .command-palette__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.8rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }

  .command-palette__header h2 {
    margin: 0;
    font-size: 0.95rem;
    color: var(--color-text);
  }

  .command-palette__header p {
    margin: 0;
    color: var(--color-text-faint);
    font-size: 0.72rem;
    letter-spacing: 0.02em;
  }

  .command-palette__header kbd {
    font: inherit;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 0.12rem 0.35rem;
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-text-muted);
  }

  .command-palette__search {
    display: block;
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid var(--color-border);
  }

  .command-palette__search input {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: rgba(5, 6, 10, 0.72);
    color: var(--color-text);
    padding: 0.62rem 0.7rem;
    font-size: 0.9rem;
  }

  .command-palette__search input::placeholder {
    color: var(--color-text-faint);
  }

  .command-palette__list {
    list-style: none;
    margin: 0;
    padding: 0.4rem;
    max-height: min(50vh, 28rem);
    overflow: auto;
    display: grid;
    gap: 0.25rem;
  }

  .command-palette__list a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    padding: 0.58rem 0.62rem;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    border: 1px solid transparent;
    transition:
      border-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      background var(--duration-fast) var(--ease-out);
  }

  .command-palette__list a:hover {
    color: var(--color-text);
    border-color: var(--color-border);
    background: rgba(255, 255, 255, 0.04);
  }

  .command-palette__arrow {
    color: var(--color-text-faint);
    font-size: 0.8rem;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }
  @media (max-width: 640px) {
    .command-palette {
      padding-inline: 0.7rem;
    }
  }
</style>
