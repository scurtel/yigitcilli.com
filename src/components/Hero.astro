---
import { site } from '@/config/site';
import ImagePlaceholder from './ImagePlaceholder.astro';

const heroAlt =
  'Yiğit Cilli — yazılım, dijital ürünler, tercüme ve stoacı düşünce';
---

<section class="hero hero--sequence" data-hero-opening data-hero aria-label="Açılış">
  <script is:inline>
    (function () {
      var el = document.currentScript && document.currentScript.parentElement;
      if (!el) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        el.dataset.opening = 'skip';
        document.body.classList.add('hero-opening-ready');
        return;
      }
      var short = document.documentElement.classList.contains('hero-opening-short');
      el.dataset.opening = short ? 'short' : 'full';
    })();
  </script>
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__grid"></div>
  </div>

  <div class="container hero__content">
    <p class="hero__eyebrow hero__seq hero__seq--eyebrow">{site.hero.eyebrow}</p>
    <h1 class="hero__title hero__seq hero__seq--title">{site.name}</h1>
    <div class="hero__desc hero__seq hero__seq--desc">
      <p class="hero__subtitle">{site.hero.subtitle}</p>
      <p class="hero__slogan">{site.slogan}</p>
    </div>
    <div class="hero__actions hero__seq hero__seq--actions">
      <a href="#alanlar" class="hero__cta hero__cta--primary motion-btn">{site.hero.ctaPrimary}</a>
      <a href={site.hero.ctaSecondaryHref} class="hero__cta hero__cta--references motion-btn">
        <span>{site.hero.ctaSecondary}</span>
        <span class="hero__cta-arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </div>

  <div class="hero__visual container hero__seq hero__seq--visual">
    <div class="hero__parallax" data-hero-parallax>
      <ImagePlaceholder
        src="/images/hero.webp"
        alt={heroAlt}
        variant="hero"
        loading="eager"
        fetchPriority="high"
        width={1280}
        height={960}
      />
    </div>
  </div>
</section>

<script src="@/scripts/hero-opening.ts"></script>
<script src="@/scripts/hero-parallax.ts"></script>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: grid;
    align-content: center;
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-2xl);
    overflow: hidden;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 82% 72% at 50% 42%, black 22%, transparent 76%);
    opacity: 0.9;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    max-width: 42rem;
    padding-block: var(--space-lg);
  }

  .hero__eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-faint);
    margin: 0 0 var(--space-md);
  }

  .hero__title {
    font-size: clamp(2.75rem, 8vw, 4.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.05;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
  }

  .hero__subtitle {
    font-size: clamp(1.05rem, 2.5vw, 1.25rem);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
    max-width: 38ch;
  }

  .hero__slogan {
    font-size: 0.9rem;
    letter-spacing: 0.04em;
    color: var(--color-text-faint);
    margin: 0;
    max-width: 34ch;
  }

  .hero__desc {
    margin: 0 0 var(--space-xl);
  }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    align-items: stretch;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 1.2rem;
    border-radius: var(--radius-sm);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .hero__cta--primary {
    background: var(--color-navy);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text);
  }

  .hero__cta--primary:hover {
    background: var(--color-surface-hover);
  }

  .hero__cta--references {
    padding: 0.85rem 1.65rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-text);
    border: 1px solid rgba(90, 125, 168, 0.55);
    background: linear-gradient(
      135deg,
      rgba(26, 39, 64, 0.95) 0%,
      rgba(61, 95, 138, 0.42) 100%
    );
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 12px 32px rgba(0, 0, 0, 0.35),
      0 0 0 1px rgba(61, 95, 138, 0.15);
  }

  .hero__cta--references:hover {
    border-color: var(--color-accent-soft);
    background: linear-gradient(
      135deg,
      rgba(26, 39, 64, 1) 0%,
      rgba(61, 95, 138, 0.55) 100%
    );
  }

  .hero__cta-arrow {
    font-size: 1.05em;
    opacity: 0.85;
    transition: transform var(--duration-micro) var(--ease-motion);
  }

  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .hero__cta--references:hover .hero__cta-arrow {
      transform: translateX(3px);
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .hero__cta--references {
      flex: 1 1 100%;
      min-width: 0;
    }
  }

  .hero__visual {
    position: relative;
    z-index: 1;
    margin-top: var(--space-lg);
    min-width: 0;
    max-width: 100%;
  }

  .hero__parallax {
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__parallax {
      will-change: auto;
    }
  }

  /* Hero açılış — eyebrow → title → desc → actions (+ görsel) */
  @media (prefers-reduced-motion: no-preference) {
    .hero--sequence:not(.hero--sequence-complete):not([data-opening='skip']) .hero__seq {
      opacity: 0;
    }

    .hero--sequence[data-opening='full'] .hero__seq--eyebrow {
      animation: motion-rise var(--duration-reveal) var(--ease-motion) 0ms forwards;
    }

    .hero--sequence[data-opening='full'] .hero__seq--title {
      animation: motion-rise var(--duration-reveal) var(--ease-motion) var(--motion-stagger) forwards;
    }

    .hero--sequence[data-opening='full'] .hero__seq--desc {
      animation: motion-rise var(--duration-reveal) var(--ease-motion) calc(var(--motion-stagger) * 2) forwards;
    }

    .hero--sequence[data-opening='full'] .hero__seq--actions {
      animation: motion-rise var(--duration-reveal) var(--ease-motion) calc(var(--motion-stagger) * 3) forwards;
    }

    .hero--sequence[data-opening='full'] .hero__seq--visual {
      animation: motion-rise var(--duration-reveal) var(--ease-motion) calc(var(--motion-stagger) * 3) forwards;
    }

    .hero--sequence[data-opening='short'] .hero__seq--eyebrow {
      animation: motion-rise 450ms var(--ease-motion) 0ms forwards;
    }

    .hero--sequence[data-opening='short'] .hero__seq--title {
      animation: motion-rise 450ms var(--ease-motion) 45ms forwards;
    }

    .hero--sequence[data-opening='short'] .hero__seq--desc {
      animation: motion-rise 450ms var(--ease-motion) 90ms forwards;
    }

    .hero--sequence[data-opening='short'] .hero__seq--actions,
    .hero--sequence[data-opening='short'] .hero__seq--visual {
      animation: motion-rise 450ms var(--ease-motion) 135ms forwards;
    }
  }

  @media (min-width: 1024px) {
    .hero {
      grid-template-columns: 1fr 1fr;
      align-items: center;
      column-gap: var(--space-xl);
    }

    .hero__visual {
      margin-top: 0;
    }
  }

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: calc(var(--header-height) + var(--space-lg));
      padding-bottom: var(--space-lg);
    }

    .hero__grid {
      background-size: 32px 32px;
    }

    .hero__visual {
      max-width: min(100%, 22rem);
      margin-inline: auto;
    }

    .hero__visual :global(.media-card--hero .media-card__frame) {
      max-height: 50vh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero--sequence[data-opening='skip'] .hero__seq,
    .hero--sequence-complete .hero__seq {
      animation: none !important;
      opacity: 1;
      transform: none;
    }
  }
</style>
