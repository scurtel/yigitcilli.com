---
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  image?: {
    src: string;
    alt: string;
  };
  compactTop?: boolean;
  /** İlk yüklemede görünür (scroll-reveal kapalı) */
  visibleOnLoad?: boolean;
  /** cover: kırparak doldurur; contain: görselin tamamını gösterir */
  imageFit?: 'cover' | 'contain';
  /** contain modunda kart oranı (ör. "1 / 1", "4 / 3") */
  imageAspectRatio?: string;
}

const {
  eyebrow,
  title,
  description,
  image,
  compactTop = false,
  visibleOnLoad = false,
  imageFit = 'cover',
  imageAspectRatio = '4 / 3',
} = Astro.props;

const containImage = imageFit === 'contain';
---

<section
  class:list={[
    'page-hero',
    'section',
    compactTop && 'page-hero--compact',
    containImage && 'page-hero--contain-image',
  ]}
  style={containImage ? `--page-hero-aspect: ${imageAspectRatio}` : undefined}
  aria-labelledby="page-hero-title"
>
  <div class="page-hero__bg" aria-hidden="true">
    <div class="page-hero__grid"></div>
  </div>

  <div class="container page-hero__inner">
    <div
      class:list={['page-hero__copy', visibleOnLoad && 'is-visible']}
      {...(!visibleOnLoad && { 'data-reveal': true })}
    >
      <p class="section__eyebrow">{eyebrow}</p>
      <h1 id="page-hero-title" class="page-hero__title">{title}</h1>
      <p class="page-hero__description">{description}</p>
    </div>

    {
      image && (
        <div class="page-hero__media is-visible">
          <ImagePlaceholder
            src={image.src}
            alt={image.alt}
            variant="section"
            loading="eager"
            fetchPriority="high"
          />
        </div>
      )
    }
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    padding-top: calc(var(--header-height) + var(--space-xl));
    padding-bottom: var(--space-xl);
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .page-hero--compact {
    padding-top: var(--space-lg);
  }

  .page-hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .page-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--grid-line) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px);
    background-size: 48px 48px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 30%, black 15%, transparent 70%);
    opacity: 0.7;
  }

  .page-hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    gap: var(--space-grid);
    align-items: center;
  }

  .page-hero__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
  }

  .page-hero__description {
    margin: 0;
    max-width: 40ch;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .page-hero__media {
    min-width: 0;
    max-width: 100%;
  }

  .page-hero__media :global(.media-card) {
    height: 100%;
  }

  .page-hero__media :global(.media-card__frame) {
    width: 100%;
    height: 100%;
    min-height: clamp(12rem, 34vw, 20rem);
    aspect-ratio: 16 / 10;
    max-height: none;
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: #111827;
    overflow: hidden;
    box-shadow: var(--shadow-panel);
  }

  .page-hero__media :global(.media-card__frame img) {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  .page-hero__media :global(.media-card__overlay) {
    background: linear-gradient(
      165deg,
      rgba(7, 8, 12, 0.2) 0%,
      rgba(7, 8, 12, 0.05) 45%,
      rgba(7, 8, 12, 0.28) 100%
    );
  }

  @media (max-width: 899px) {
    .page-hero__media {
      order: 2;
    }

    .page-hero__copy {
      order: 1;
    }

    .page-hero__media :global(.media-card__frame) {
      min-height: clamp(11rem, 52vw, 16rem);
      aspect-ratio: 16 / 11;
    }
  }

  @media (min-width: 900px) {
    .page-hero__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-grid-lg);
    }
  }

  .page-hero--contain-image .page-hero__media :global(.media-card__frame) {
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: var(--page-hero-aspect, 4 / 3);
    min-height: clamp(14rem, 42vw, 24rem);
    max-height: min(28rem, 72vh);
  }

  .page-hero--contain-image .page-hero__media :global(.media-card__frame img) {
    object-fit: contain;
    object-position: center;
  }

  .page-hero--contain-image .page-hero__media :global(.media-card__overlay) {
    background: linear-gradient(
      165deg,
      rgba(7, 8, 12, 0.08) 0%,
      transparent 45%,
      rgba(7, 8, 12, 0.12) 100%
    );
  }

  @media (max-width: 899px) {
    .page-hero--contain-image .page-hero__media :global(.media-card__frame) {
      aspect-ratio: var(--page-hero-aspect, 4 / 3);
      min-height: clamp(13rem, 78vw, 20rem);
      max-height: none;
    }
  }
</style>
