---
interface Props {
  src: string;
  alt: string;
  variant?: 'section' | 'hero' | 'card';
  loading?: 'lazy' | 'eager';
  fetchPriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
}

const {
  src,
  alt,
  variant = 'section',
  loading = 'lazy',
  fetchPriority = 'auto',
  width = 800,
  height = 600,
} = Astro.props;
---

<figure
  class:list={['media-card', `media-card--${variant}`]}
  data-media-card
>
  <div class="media-card__frame">
    <img
      src={src}
      alt={alt}
      width={width}
      height={height}
      loading={loading}
      decoding="async"
      fetchpriority={fetchPriority}
    />
    <div class="media-card__overlay" aria-hidden="true"></div>
  </div>
</figure>

<style>
  .media-card {
    margin: 0;
    max-width: 100%;
  }

  .media-card__frame {
    position: relative;
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    overflow: hidden;
    isolation: isolate;
    box-shadow: var(--shadow-panel);
    transition:
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .media-card--section .media-card__frame {
    aspect-ratio: 16 / 10;
    max-height: 20rem;
  }

  .media-card--card .media-card__frame {
    aspect-ratio: 4 / 3;
    min-height: 11rem;
  }

  .media-card--hero .media-card__frame {
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-panel), var(--shadow-glow);
  }

  .media-card__frame img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.97) saturate(0.95);
    transform: scale(1);
    transition:
      transform var(--duration-slow) var(--ease-out),
      filter var(--duration-base) var(--ease-out);
  }

  .media-card__overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background: linear-gradient(
      165deg,
      rgba(7, 8, 12, 0.28) 0%,
      rgba(7, 8, 12, 0.08) 42%,
      rgba(7, 8, 12, 0.38) 100%
    );
  }

  .media-card--hero .media-card__overlay {
    background: linear-gradient(
      180deg,
      rgba(7, 8, 12, 0.12) 0%,
      rgba(7, 8, 12, 0.22) 50%,
      rgba(7, 8, 12, 0.48) 100%
    );
  }

  @media (hover: hover) {
    .media-card__frame:hover {
      border-color: var(--color-border-strong);
    }

    .media-card__frame:hover img {
      transform: scale(1.01);
      filter: brightness(0.94) saturate(0.92);
    }
  }

  @media (max-width: 768px) {
    .media-card__frame img {
      filter: brightness(0.94) saturate(0.95);
    }

    .media-card--section .media-card__frame {
      aspect-ratio: 16 / 11;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .media-card__frame,
    .media-card__frame img {
      transition: none;
    }

    .media-card__frame:hover img {
      transform: none;
    }
  }
</style>
