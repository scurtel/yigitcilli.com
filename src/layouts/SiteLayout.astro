---
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumb, { type BreadcrumbItem } from '@/components/Breadcrumb.astro';
import CommandPalette from '@/components/CommandPalette.astro';

interface Props {
  title: string;
  description: string;
  ogDescription?: string;
  ogImage?: string;
  preloadHero?: boolean;
  heroOpening?: boolean;
  breadcrumb?: BreadcrumbItem[];
}

const { title, description, ogDescription, ogImage, preloadHero, heroOpening, breadcrumb } =
  Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogDescription={ogDescription}
  ogImage={ogImage}
  preloadHero={preloadHero}
  heroOpening={heroOpening}
>
  <Header />
  <CommandPalette />
  {breadcrumb && breadcrumb.length > 0 && <Breadcrumb items={breadcrumb} />}
  <main id="main">
    <slot />
  </main>
  <Footer />
</BaseLayout>

<style>
  main {
    position: relative;
  }
</style>
