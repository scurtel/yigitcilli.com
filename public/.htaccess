# yigitcilli.com — WordPress → Astro geçişi (Hostinger / Apache)
# dist/ köküne deploy edildiğinde public/.htaccess ile birlikte gelir.

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# HTTPS (Hostinger SSL aktifse — isteğe bağlı, sorun olursa yorum satırı yapın)
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# WordPress kalıntıları → ana site haritası veya ana sayfa
RewriteRule ^wp-admin - [F,L]
RewriteRule ^wp-login\.php - [F,L]
RewriteRule ^wp-content/ - [F,L]
RewriteRule ^xmlrpc\.php - [F,L]

RewriteRule ^post-sitemap\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^page-sitemap\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^category-sitemap\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^sitemap-posttype-post\.xml$ /sitemap.xml [R=301,L]
RewriteRule ^sitemap-posttype-page\.xml$ /sitemap.xml [R=301,L]

RewriteRule ^feed/?$ / [R=301,L]
RewriteRule ^comments/feed/?$ / [R=301,L]
RewriteRule ^index\.php$ / [R=301,L]

# Trailing slash: dizin yapısı (/sayfa/) — dosya yoksa slash ekle
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]{2,5}$
RewriteRule ^(.*)$ /$1/ [R=301,L]
</IfModule>

# Önbellek ve sıkıştırma (Hostinger genelde etkin)
<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
